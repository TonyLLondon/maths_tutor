    "21": {
      "display": "Cutting a right-angled triangle from one end of the parallelogram and sliding it to the other end forms a rectangle with the same base and height, so the parallelogram's area equals base × height, just like a rectangle.",
      "accept": [
        "rectangle",
        "same area"
      ],
      "tier": 2,
      "contains": true,
      "rating": 1180
    },
    "22": {
      "display": "Splitting the trapezium into a rectangle (width = the shorter parallel side) and a triangle (base = the difference between the two parallel sides) and adding their areas gives exactly 1/2 × (a + b) × h.",
      "accept": [
        "rectangle",
        "triangle"
      ],
      "tier": 2,
      "contains": true,
      "rating": 1223
    },
